<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════════
         CORE PERMISSIONS
         ════════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Optional browser package visibility -->
    <queries>
        <package android:name="com.android.chrome" />
        <package android:name="com.microsoft.emmx" />
        <package android:name="com.brave.browser" />
    </queries>

    <application
        android:name=".RakshakXApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RakshakX"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <!-- ════════════════════════════════════════════════════════════
             ACTIVITIES
             ════════════════════════════════════════════════════════════ -->

        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RakshakX">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX" />

        <!-- Call channel -->
        <activity
            android:name=".call.CallMainActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX.Call" />

        <activity
            android:name=".call.callanalysis.ui.RakshakXActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX.Call" />

        <activity
            android:name=".call.callanalysis.ui.PermissionSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX.Call" />

        <activity
            android:name=".call.callanalysis.CallOverlayActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX.CallOverlay" />

        <activity
            android:name=".call.callanalysis.FraudAlertActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX.FraudAlert" />

        <activity
            android:name=".call.callanalysis.SafeCallActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX.SafeCall" />

        <!-- SMS -->
        <activity
            android:name=".sms.SmsMainActivity"
            android:exported="false"
            android:theme="@style/Theme.RakshakX" />

        <!-- ════════════════════════════════════════════════════════════
             SERVICES
             ════════════════════════════════════════════════════════════ -->

        <!-- Foreground fraud monitoring -->
        <service
            android:name=".call.services.foreground.FraudMonitoringForegroundService"
            android:exported="false" />

        <!-- Call recording -->
        <service
            android:name=".call.callanalysis.CallRecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone"
            tools:replace="android:foregroundServiceType" />

        <!-- Overlay -->
        <service
            android:name=".call.callanalysis.OverlayBubbleService"
            android:exported="false" />

        <!-- Hackathon mode -->
        <service
            android:name=".call.callanalysis.HackathonModeCallMonitorService"
            android:exported="false" />

        <!-- Unified notification listener -->
        <service
            android:name=".sms.NotificationService"
            android:exported="true"
            android:label="RakshakX Fraud Guard"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
            <meta-data
                android:name="android.service.notification.default_filter_types"
                android:value="conversations" />
        </service>

        <!-- Accessibility -->
        <service
            android:name=".web.services.AccessibilityMonitorService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- VPN -->
        <service
            android:name=".web.services.FraudVpnService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:permission="android.permission.BIND_VPN_SERVICE"
            tools:replace="android:foregroundServiceType,android:exported">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- ════════════════════════════════════════════════════════════
             RECEIVERS
             ════════════════════════════════════════════════════════════ -->

        <!-- Boot -->
        <receiver
            android:name=".sms.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- SMS event receiver -->
        <receiver
            android:name=".call.services.receivers.SmsEventReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- SMS fallback receiver -->
        <receiver
            android:name=".sms.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="2147483647">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Call state -->
        <receiver
            android:name=".call.callanalysis.CallStateReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Notification action -->
        <receiver
            android:name=".call.callanalysis.NotificationActionReceiver"
            android:exported="false" />

    </application>

</manifest>
