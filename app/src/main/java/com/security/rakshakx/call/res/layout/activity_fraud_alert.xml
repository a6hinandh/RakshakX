<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#D32F2F"
    android:padding="24dp">

    <!-- Warning Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚠️"
        android:textSize="100sp"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FRAUD CALL DETECTED"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Phone Number -->
    <TextView
        android:id="@+id/tvPhoneNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+91 9876543210"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- Risk Score Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RISK SCORE"
        android:textSize="14sp"
        android:textColor="#FFCCCC"
        android:layout_marginBottom="8dp" />

    <!-- Risk Score Value -->
    <TextView
        android:id="@+id/tvRiskScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="85%"
        android:textSize="64sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- Detected Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="THREATS DETECTED:"
        android:textSize="14sp"
        android:textColor="#FFCCCC"
        android:layout_marginBottom="12dp" />

    <!-- Reason -->
    <TextView
        android:id="@+id/tvReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OTP phishing, account suspension threat, urgent language"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="48dp"
        android:paddingHorizontal="16dp" />

    <!-- Warning Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚨 HANG UP IMMEDIATELY 🚨"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFEB3B"
        android:layout_marginBottom="32dp" />

    <!-- Auto-dismiss hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(Dismissing automatically...)"
        android:textSize="14sp"
        android:textColor="#FFCCCC"
        android:fontFamily="sans-serif-light" />

</LinearLayout>
