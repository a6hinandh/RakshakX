<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayoutSafe"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#4CAF50"
    android:padding="24dp">

    <!-- Check Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅"
        android:textSize="100sp"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SAFE CALL"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Phone Number -->
    <TextView
        android:id="@+id/tvPhoneNumberSafe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+91 9876543210"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- Risk Score Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RISK SCORE"
        android:textSize="14sp"
        android:textColor="#C8E6C9"
        android:layout_marginBottom="8dp" />

    <!-- Risk Score Value -->
    <TextView
        android:id="@+id/tvRiskScoreSafe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15%"
        android:textSize="56sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- Safe Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓ No threats detected"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <!-- Auto-dismiss hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(Dismissing automatically...)"
        android:textSize="14sp"
        android:textColor="#C8E6C9"
        android:fontFamily="sans-serif-light" />

</LinearLayout>